#!/bin/sh
# CASA pre-commit: machine enforcement of the CLAUDE.md working rules.
# Activate once per clone: git config core.hooksPath scripts/git-hooks

branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" = "main" ] && [ -z "$CASA_ALLOW_MAIN" ]; then
  echo "pre-commit: direct commits to main are blocked (CLAUDE.md: PR-only)." >&2
  echo "  use a feature branch; emergency override: CASA_ALLOW_MAIN=1 git commit ..." >&2
  exit 1
fi

if [ -x ".venv/Scripts/python.exe" ]; then
  py=".venv/Scripts/python.exe"
elif [ -x ".venv/bin/python" ]; then
  py=".venv/bin/python"
else
  echo "pre-commit: .venv not found. Create it first:" >&2
  echo "  python -m venv .venv && .venv/Scripts/pip install -e '.[dev]'" >&2
  exit 1
fi

"$py" -m pytest -q || {
  echo "pre-commit: tests failed - commit aborted (CLAUDE.md: no failing commits)." >&2
  exit 1
}
